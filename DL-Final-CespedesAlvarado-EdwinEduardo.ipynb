        "# === ANÁLISIS SHAP ===\n",
        "\n",
        "try:\n",
        "    import shap\n",
        "    print('✅ SHAP disponible.')\n",
        "except ImportError:\n",
        "    print('⚠️  SHAP no instalado. Instalando...')\n",
        "    import subprocess\n",
        "    subprocess.run(['pip', 'install', 'shap', '-q'])\n",
        "    import shap\n",
        "\n",
        "# Usar una muestra para el análisis SHAP (por eficiencia)\n",
        "N_SHAP = min(500, len(X_test_sc))\n",
        "X_shap_sample = X_test_sc[:N_SHAP]\n",
        "\n",
        "print(f'🔄 Calculando valores SHAP para {N_SHAP} muestras...')\n",
        "\n",
        "# Background data: submuestra del train para KernelExplainer\n",
        "background = X_train_sm[:100]\n",
        "\n",
        "explainer = shap.KernelExplainer(\n",
        "    lambda x: model_dnn.predict(x, verbose=0),\n",
        "    background\n",
        ")\n",
        "\n",
        "shap_values = explainer.shap_values(X_shap_sample, nsamples=100, silent=True)\n",
        "\n",
        "# Aplanar dimensión extra si shap_values tiene shape (n, features, 1)\n",
        "shap_vals = np.array(shap_values)\n",
        "if shap_vals.ndim == 3:\n",
        "    shap_vals = shap_vals[:, :, 0]  # → (n_samples, n_features)\n",
        "\n",
        "# Calcular importancia media absoluta\n",
        "mean_shap = np.abs(shap_vals).mean(axis=0)\n",
        "shap_importance = pd.Series(mean_shap, index=FEATURE_COLS).sort_values(ascending=True)\n",
        "\n",
        "# === VISUALIZACIÓN ===\n",
        "fig, axes = plt.subplots(1, 2, figsize=(16, 7))\n",
        "fig.suptitle('Análisis SHAP: Importancia de Variables en el Modelo DNN',\n",
        "             fontsize=14, fontweight='bold')\n",
        "\n",
        "# --- Bar plot de importancia global ---\n",
        "ax1 = axes[0]\n",
        "colors_shap = [COLORS['mora'] if v > shap_importance.median() else COLORS['secondary']\n",
        "               for v in shap_importance.values]\n",
        "ax1.barh(shap_importance.index, shap_importance.values, color=colors_shap)\n",
        "ax1.set_xlabel('|SHAP value| medio (impacto en predicción)', fontsize=11)\n",
        "ax1.set_title('Importancia Global de Variables (SHAP)', fontweight='bold')\n",
        "ax1.axvline(shap_importance.median(), color='gray', linestyle='--', alpha=0.7)\n",
        "\n",
        "for i, (feat, val) in enumerate(shap_importance.tail(5).items()):\n",
        "    ax1.text(val + 0.001, len(shap_importance) - 5 + i, f'{val:.3f}',\n",
        "             va='center', fontsize=9, fontweight='bold')\n",
        "\n",
        "# --- Violin plot: distribución SHAP top 5 variables ---\n",
        "ax2 = axes[1]\n",
        "top5_features = shap_importance.tail(5).index.tolist()\n",
