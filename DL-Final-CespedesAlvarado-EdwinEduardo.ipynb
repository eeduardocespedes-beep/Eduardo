        "# === DEFINICIÓN DEL MODELO DNN ===\n",
        "\n",
        "def build_dnn_model(input_dim, dropout_rate=0.3, l2_reg=0.001):\n",
        "    \"\"\"\n",
        "    Construye la Red Neuronal Profunda para predicción de mora.\n",
        "\n",
        "    Arquitectura:\n",
        "    - Input: 20 features\n",
        "    - Dense(256) + BatchNorm + Dropout(0.3)\n",
        "    - Dense(128) + BatchNorm + Dropout(0.3)\n",
        "    - Dense(64)  + Dropout(0.2)\n",
        "    - Dense(32)  + Dropout(0.2)\n",
        "    - Dense(1, sigmoid) -> Probabilidad de mora\n",
        "    \"\"\"\n",
        "    model = Sequential([\n",
        "        # === CAPA DE ENTRADA ===\n",
        "        layers.Input(shape=(input_dim,), name='input_features'),\n",
        "\n",
        "        # === CAPA 1: 256 neuronas ===\n",
        "        Dense(256, kernel_regularizer=regularizers.l2(l2_reg), name='dense_1'),\n",
        "        BatchNormalization(name='bn_1'),\n",
        "        layers.Activation('relu', name='relu_1'),\n",
        "        Dropout(dropout_rate, name='dropout_1'),\n",
        "\n",
        "        # === CAPA 2: 128 neuronas ===\n",
        "        Dense(128, kernel_regularizer=regularizers.l2(l2_reg), name='dense_2'),\n",
        "        BatchNormalization(name='bn_2'),\n",
        "        layers.Activation('relu', name='relu_2'),\n",
        "        Dropout(dropout_rate, name='dropout_2'),\n",
        "\n",
        "        # === CAPA 3: 64 neuronas ===\n",
        "        Dense(64, kernel_regularizer=regularizers.l2(l2_reg/2), name='dense_3'),\n",
        "        layers.Activation('relu', name='relu_3'),\n",
        "        Dropout(0.2, name='dropout_3'),\n",
        "\n",
        "        # === CAPA 4: 32 neuronas ===\n",
        "        Dense(32, name='dense_4'),\n",
        "        layers.Activation('relu', name='relu_4'),\n",
        "        Dropout(0.2, name='dropout_4'),\n",
        "\n",
        "        # === CAPA DE SALIDA: 1 neurona, sigmoid ===\n",
        "        Dense(1, activation='sigmoid', name='output')\n",
        "    ])\n",
        "\n",
        "    return model\n",
        "\n",
        "\n",
        "# Construir el modelo\n",
        "INPUT_DIM = X_train_sm.shape[1]\n",
        "model_dnn = build_dnn_model(input_dim=INPUT_DIM)\n",
        "\n",
        "# === COMPILACIÓN ===\n",
        "model_dnn.compile(\n",
        "    optimizer=keras.optimizers.Adam(learning_rate=0.001, beta_1=0.9, beta_2=0.999),\n",
        "    loss='binary_crossentropy',\n",
        "    metrics=[\n",
        "        'accuracy',\n",
        "        keras.metrics.AUC(name='auc'),\n",
        "        keras.metrics.Precision(name='precision'),\n",
        "        keras.metrics.Recall(name='recall')\n",
        "    ]\n",
        ")\n",
        "\n",
        "# Resumen de la arquitectura\n",
        "print('=' * 60)\n",
        "print('🏗️  ARQUITECTURA DEL MODELO DNN')\n",
        "print('=' * 60)\n",
        "model_dnn.summary()\n",
        "\n",
        "total_params = model_dnn.count_params()\n",
        "print(f'\\nTotal de parámetros: {total_params:,}')"
      ]
    },
