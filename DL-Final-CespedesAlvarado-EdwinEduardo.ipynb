        "    'pay_amt_mes1': 30000,\n",
        "    'pay_amt_mes2': 28000\n",
        "}\n",
        "prob2 = predecir_mora_cliente(cliente_bajo_riesgo, model_dnn, scaler, FEATURE_COLS)\n",
