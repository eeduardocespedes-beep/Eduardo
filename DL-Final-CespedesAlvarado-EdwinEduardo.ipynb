        "# === PREDICCIÓN PARA NUEVOS CLIENTES ===\n",
        "\n",
        "def predecir_mora_cliente(cliente_dict, modelo, scaler, feature_cols, threshold=0.40):\n",
        "    \"\"\"\n",
        "    Predice la probabilidad de mora para un nuevo cliente.\n",
        "\n",
        "    Parámetros:\n",
        "    -----------\n",
        "    cliente_dict : dict con las características del cliente\n",
        "    modelo : modelo DNN entrenado\n",
        "    scaler : StandardScaler ajustado en entrenamiento\n",
        "    feature_cols : lista de columnas en orden correcto\n",
        "    threshold : umbral de decisión (default=0.40)\n",
        "    \"\"\"\n",
        "    # Construir vector de características\n",
        "    X_nuevo = np.array([[cliente_dict.get(col, 0) for col in feature_cols]])\n",
        "    X_nuevo_sc = scaler.transform(X_nuevo)\n",
        "\n",
        "    # Predicción\n",
        "    prob_mora = modelo.predict(X_nuevo_sc, verbose=0)[0, 0]\n",
        "    clasificacion = 'MORA ALTA' if prob_mora >= threshold else 'SIN MORA'\n",
        "    semaforo = '🔴' if prob_mora >= 0.6 else '🟡' if prob_mora >= threshold else '🟢'\n",
        "\n",
        "    print(f'\\n{\"=\"*55}')\n",
        "    print(f'🏦 RESULTADO DE EVALUACIÓN CREDITICIA')\n",
        "    print(f'{\"=\"*55}')\n",
        "    print(f'Probabilidad de mora: {prob_mora:.1%}')\n",
        "    print(f'Clasificación:        {semaforo} {clasificacion}')\n",
        "    print(f'Umbral de decisión:   {threshold:.0%}')\n",
        "    print(f'\\n📋 Recomendación:')\n",
        "    if prob_mora >= 0.6:\n",
        "        print('   → DENEGAR o exigir garantías adicionales')\n",
        "        print('   → Activar protocolo de cobranza preventiva')\n",
        "    elif prob_mora >= threshold:\n",
        "        print('   → REVISAR manualmente con analista de crédito')\n",
        "        print('   → Considerar monto menor o plazo reducido')\n",
        "    else:\n",
        "        print('   → APROBAR según condiciones estándar')\n",
        "    print(f'{\"=\"*55}')\n",
        "\n",
        "    return prob_mora\n",
        "\n",
        "\n",
        "# Ejemplo 1: Cliente de ALTO riesgo\n",
        "print('\\n🧑 CLIENTE 1 - Perfil de ALTO RIESGO:')\n",
        "cliente_alto_riesgo = {\n",
        "    'age': 35,\n",
        "    'gender': 1,\n",
        "    'education': 3,\n",
        "    'marital_status': 2,\n",
        "    'credit_limit': 20000,\n",
