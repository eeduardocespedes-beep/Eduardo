      "source": [
        "# === PREPROCESAMIENTO ===\n",
        "\n",
        "# 1. Codificación de variable categórica\n",
        "le = LabelEncoder()\n",
        "df['loan_purpose_enc'] = le.fit_transform(df['loan_purpose'])\n",
        "\n",
        "# 2. Definir features y target\n",
        "FEATURE_COLS = [\n",
        "    'age', 'gender', 'education', 'marital_status', 'credit_limit',\n",
        "    'credit_score', 'payment_ratio', 'days_overdue', 'num_prev_defaults',\n",
        "    'employment_months', 'debt_to_income', 'utilizacion_credito',\n",
        "    'loan_purpose_enc', 'pay_hist_mes1', 'pay_hist_mes2', 'pay_hist_mes3',\n",
        "    'bill_amt_mes1', 'bill_amt_mes2', 'pay_amt_mes1', 'pay_amt_mes2'\n",
        "]\n",
        "\n",
        "TARGET_COL = 'DEFAULT'\n",
        "\n",
        "X = df[FEATURE_COLS].values\n",
        "y = df[TARGET_COL].values\n",
        "\n",
        "print(f'Shape de X: {X.shape}  |  Shape de y: {y.shape}')\n",
        "print(f'Número de features: {len(FEATURE_COLS)}')\n",
        "\n",
        "# 3. División train/val/test (70/15/15) - estratificada\n",
        "X_temp, X_test, y_temp, y_test = train_test_split(\n",
        "    X, y, test_size=0.15, random_state=SEED, stratify=y\n",
        ")\n",
        "X_train, X_val, y_train, y_val = train_test_split(\n",
        "    X_temp, y_temp, test_size=0.1765, random_state=SEED, stratify=y_temp  # 0.1765 * 0.85 ≈ 0.15\n",
        ")\n",
        "\n",
        "print(f'\\nDivisión del dataset:')\n",
        "print(f'  Entrenamiento: {X_train.shape[0]:,} ({X_train.shape[0]/len(X)*100:.1f}%)')\n",
        "print(f'  Validación:    {X_val.shape[0]:,} ({X_val.shape[0]/len(X)*100:.1f}%)')\n",
        "print(f'  Prueba:        {X_test.shape[0]:,} ({X_test.shape[0]/len(X)*100:.1f}%)')\n",
        "\n",
        "# 4. Normalización (StandardScaler ajustado SOLO en train)\n",
        "scaler = StandardScaler()\n",
        "X_train_sc = scaler.fit_transform(X_train)\n",
        "X_val_sc = scaler.transform(X_val)\n",
        "X_test_sc = scaler.transform(X_test)\n",
        "\n",
        "# 5. SMOTE solo sobre el conjunto de ENTRENAMIENTO\n",
        "print(f'\\nAntes de SMOTE - train mora: {y_train.sum():,} ({y_train.mean()*100:.1f}%)')\n",
        "# sampling_strategy='auto' oversamples la clase minoritaria hasta igualar a la mayoritaria\n",
        "# Solo se aplica si la clase 1 es menor que la clase 0; si ya está balanceado, no hace nada dañino\n",
        "current_ratio = y_train.mean()\n",
        "minority_ratio = min(current_ratio, 1 - current_ratio) / max(current_ratio, 1 - current_ratio)\n",
        "\n",
        "if current_ratio < 0.40:\n",
        "    # Clase 1 es minoría real → SMOTE con ratio mayor al actual\n",
        "    target_strategy = max(0.75, minority_ratio + 0.10)\n",
        "    smote = SMOTE(random_state=SEED, k_neighbors=5, sampling_strategy=target_strategy)\n",
        "    X_train_sm, y_train_sm = smote.fit_resample(X_train_sc, y_train)\n",
        "    print(f'  ✅ SMOTE aplicado (sampling_strategy={target_strategy:.2f})')\n",
        "else:\n",
        "    # Dataset ya suficientemente balanceado → no se necesita SMOTE\n",
        "    print(f'  ⚠️  Ratio actual ({current_ratio*100:.1f}%) suficientemente balanceado.')\n",
        "    print('      Se omite SMOTE y se compensa con class_weight en el modelo DNN.')\n",
        "    X_train_sm, y_train_sm = X_train_sc, y_train\n",
        "print(f'Después: train mora: {y_train_sm.sum():,} ({y_train_sm.mean()*100:.1f}%)')\n",
        "print(f'Total muestras de entrenamiento: {len(X_train_sm):,}')\n",
        "\n",
        "# Visualizar efecto de SMOTE\n",
        "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
        "for ax, y_data, title in zip(axes, [y_train, y_train_sm], ['Antes de SMOTE', 'Después de SMOTE']):\n",
        "    vc = pd.Series(y_data).value_counts()\n",
        "    bars = ax.bar(['Sin Mora', 'Con Mora'], vc.values,\n",
        "                  color=[COLORS['no_mora'], COLORS['mora']], edgecolor='white')\n",
        "    for bar, val in zip(bars, vc.values):\n",
        "        ax.text(bar.get_x()+bar.get_width()/2, bar.get_height()+50,\n",
        "                f'{val:,}', ha='center', fontweight='bold')\n",
        "    ax.set_title(f'Train - {title}', fontweight='bold')\n",
        "    ax.set_ylabel('Número de muestras')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('/tmp/smote_effect.png', dpi=150, bbox_inches='tight')\n",
        "plt.show()\n",
        "print('✅ Preprocesamiento y SMOTE completados.')"
      ]
    },
