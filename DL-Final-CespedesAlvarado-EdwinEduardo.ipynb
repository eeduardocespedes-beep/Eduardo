      "source": [
        "# === SIMULADOR DE IMPACTO ECONÓMICO ===\n",
        "\n",
        "def simular_impacto_economico(\n",
        "    cartera_total_millones,\n",
        "    tasa_mora_pct,\n",
        "    lgd_pct,\n",
        "    recall_modelo,\n",
        "    tasa_rescate_pct,\n",
        "    costo_intervencion_por_cliente,\n",
        "    ticket_promedio,\n",
        "    nombre_entidad='Institución Financiera'\n",
        "):\n",
        "    \"\"\"\n",
        "    Simula el impacto económico del modelo de predicción de mora.\n",
        "\n",
        "    Parámetros:\n",
        "    -----------\n",
        "    cartera_total_millones : float - Cartera total en millones de moneda local\n",
        "    tasa_mora_pct : float - Tasa de mora actual (%)\n",
        "    lgd_pct : float - Loss Given Default: % del crédito que no se recupera\n",
        "    recall_modelo : float - Recall del modelo sobre clientes morosos (0-1)\n",
        "    tasa_rescate_pct : float - % de clientes detectados que se pueden rescatar\n",
        "    costo_intervencion_por_cliente : float - Costo de contactar/gestionar cada cliente en riesgo\n",
        "    ticket_promedio : float - Monto promedio del crédito\n",
        "    \"\"\"\n",
        "    # Cálculos base\n",
        "    cartera = cartera_total_millones * 1_000_000\n",
        "    cartera_morosa = cartera * (tasa_mora_pct / 100)\n",
        "    n_clientes_totales = int(cartera / ticket_promedio)\n",
        "    n_morosos_reales = int(cartera_morosa / ticket_promedio)\n",
        "\n",
        "    perdida_sin_modelo = cartera_morosa * (lgd_pct / 100)\n",
        "\n",
        "    # Con el modelo\n",
        "    morosos_detectados = int(n_morosos_reales * recall_modelo)\n",
        "    morosos_rescatados = int(morosos_detectados * (tasa_rescate_pct / 100))\n",
        "    credito_rescatado = morosos_rescatados * ticket_promedio\n",
        "    perdida_evitada = credito_rescatado * (lgd_pct / 100)\n",
        "\n",
        "    # Costos del modelo\n",
        "    costo_total_intervencion = morosos_detectados * costo_intervencion_por_cliente\n",
        "    costo_falsos_positivos = int(n_clientes_totales * (1 - tasa_mora_pct/100) * 0.04) * (costo_intervencion_por_cliente * 0.5)  # 4% FP rate, costo parcial\n",
        "    costo_total = costo_total_intervencion + costo_falsos_positivos\n",
        "\n",
        "    # Beneficio neto\n",
        "    beneficio_neto = perdida_evitada - costo_total\n",
        "    roi = (beneficio_neto / max(costo_total, 1)) * 100\n",
        "\n",
        "    # Reducción de tasa de mora\n",
        "    nueva_cartera_morosa = cartera_morosa - credito_rescatado\n",
        "    nueva_tasa_mora = (nueva_cartera_morosa / cartera) * 100\n",
        "\n",
        "    print('=' * 68)\n",
        "    print(f'💼 SIMULACIÓN DE IMPACTO ECONÓMICO - {nombre_entidad}')\n",
        "    print('=' * 68)\n",
        "    print(f'\\n📊 PARÁMETROS DE ENTRADA:')\n",
        "    print(f'   Cartera total:              S/ {cartera_total_millones:,.1f} M')\n",
        "    print(f'   Tasa de mora actual:        {tasa_mora_pct:.1f}%')\n",
        "    print(f'   LGD (Loss Given Default):   {lgd_pct:.0f}%')\n",
        "    print(f'   Recall del modelo DNN:      {recall_modelo*100:.0f}%')\n",
        "    print(f'   Tasa de rescate:            {tasa_rescate_pct:.0f}%')\n",
        "    print(f'   Ticket promedio:            S/ {ticket_promedio:,.0f}')\n",
        "\n",
        "    print(f'\\n📉 SITUACIÓN SIN MODELO:')\n",
        "    print(f'   Clientes totales:           {n_clientes_totales:,}')\n",
        "    print(f'   Clientes morosos:           {n_morosos_reales:,} ({tasa_mora_pct:.1f}%)')\n",
        "    print(f'   Cartera morosa:             S/ {cartera_morosa/1e6:,.2f} M')\n",
        "    print(f'   Pérdida esperada (LGD):     S/ {perdida_sin_modelo/1e6:,.2f} M')\n",
        "\n",
        "    print(f'\\n🤖 SITUACIÓN CON MODELO DNN (recall={recall_modelo*100:.0f}%):')\n",
        "    print(f'   Morosos detectados:         {morosos_detectados:,} de {n_morosos_reales:,}')\n",
        "    print(f'   Clientes rescatados:        {morosos_rescatados:,} ({tasa_rescate_pct:.0f}% de detectados)')\n",
        "    print(f'   Crédito rescatado:          S/ {credito_rescatado/1e6:,.2f} M')\n",
