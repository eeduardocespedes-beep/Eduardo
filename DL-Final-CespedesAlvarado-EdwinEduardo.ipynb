        "    'pay_hist_mes3': 2,\n",
        "    'bill_amt_mes1': 18500,\n",
        "    'bill_amt_mes2': 17200,\n",
        "    'pay_amt_mes1': 500,\n",
        "    'pay_amt_mes2': 800\n",
        "}\n",
        "prob1 = predecir_mora_cliente(cliente_alto_riesgo, model_dnn, scaler, FEATURE_COLS)\n",
        "\n",
        "# Ejemplo 2: Cliente de BAJO riesgo\n",
        "print('\\n🧑 CLIENTE 2 - Perfil de BAJO RIESGO:')\n",
        "cliente_bajo_riesgo = {\n",
