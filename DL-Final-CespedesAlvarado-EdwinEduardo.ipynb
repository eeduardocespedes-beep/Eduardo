      "source": [
        "# === ENTRENAMIENTO DEL MODELO DNN ===\n",
        "\n",
        "# Pesos de clase para penalizar falsos negativos (clientes morosos no detectados)\n",
        "CLASS_WEIGHT = {0: 1.0, 1: 3.0}  # Penaliza 3x más los errores en clase mora\n",
        "\n",
        "# Callbacks\n",
        "callback_list = [\n",
        "    EarlyStopping(\n",
        "        monitor='val_auc', mode='max', patience=15,\n",
        "        restore_best_weights=True, verbose=1\n",
        "    ),\n",
        "    ReduceLROnPlateau(\n",
        "        monitor='val_loss', factor=0.5, patience=8,\n",
        "        min_lr=1e-6, verbose=1\n",
        "    ),\n",
        "    ModelCheckpoint(\n",
        "        '/tmp/best_dnn_model.h5', monitor='val_auc',\n",
        "        save_best_only=True, mode='max', verbose=0\n",
        "    )\n",
        "]\n",
        "\n",
        "print('🚀 Iniciando entrenamiento del modelo DNN...')\n",
        "print(f'   Muestras de entrenamiento (post-SMOTE): {X_train_sm.shape[0]:,}')\n",
        "print(f'   Muestras de validación: {X_val_sc.shape[0]:,}')\n",
        "print(f'   Class weight: {CLASS_WEIGHT}')\n",
        "print('   Entrenando...')\n",
        "\n",
        "history = model_dnn.fit(\n",
        "    X_train_sm, y_train_sm,\n",
        "    validation_data=(X_val_sc, y_val),\n",
        "    epochs=100,\n",
        "    batch_size=256,\n",
        "    class_weight=CLASS_WEIGHT,\n",
        "    callbacks=callback_list,\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "print('\\n✅ Entrenamiento completado.')"
      ]
    },
