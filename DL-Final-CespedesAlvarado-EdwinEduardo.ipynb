        "            f'{prob:.1%}', ha='center', fontsize=14, fontweight='bold')\n",
        "ax.set_ylabel('Probabilidad de Mora (%)')\n",
        "ax.set_title('Comparación de Probabilidad de Mora por Cliente', fontweight='bold')\n",
        "ax.set_ylim(0, 100)\n",
        "ax.legend()\n",
        "plt.tight_layout()\n",
        "plt.savefig('/tmp/client_comparison.png', dpi=150, bbox_inches='tight')\n",
        "plt.show()"
